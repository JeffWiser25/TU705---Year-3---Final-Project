/* Includes ------------------------------------------------------------------*/
#include "main.h"
#include <stdio.h>
#include <string.h>

/* Private define ------------------------------------------------------------*/
/* USER CODE BEGIN PD */
#define TCRT_GPIO_Port   GPIOB
#define TCRT_Pin         GPIO_PIN_0

#define LED_GPIO_Port    GPIOA
#define LED_Pin          GPIO_PIN_5
/* USER CODE END PD */

/* Private variables ---------------------------------------------------------*/
UART_HandleTypeDef huart2;

/* USER CODE BEGIN PV */
volatile uint32_t encoder_count = 0;
uint8_t white_detected = 0;
uint8_t last_white_state = 0;
uint32_t last_sample_time = 0;
uint32_t last_print_time = 0;
/* USER CODE END PV */

/* Private function prototypes -----------------------------------------------*/
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_USART2_UART_Init(void);

/* USER CODE BEGIN PFP */
uint8_t TCRT5000_IsWhite(void);
void UART2_SendString(const char *str);
void Print_Status(void);
/* USER CODE END PFP */

/* Private user code ---------------------------------------------------------*/
/* USER CODE BEGIN 0 */

uint8_t TCRT5000_IsWhite(void)
{
  /* If logic is backwards, change RESET to SET */
  return (HAL_GPIO_ReadPin(TCRT_GPIO_Port, TCRT_Pin) == GPIO_PIN_RESET) ? 1U : 0U;
}

void UART2_SendString(const char *str)
{
  HAL_UART_Transmit(&huart2, (uint8_t *)str, strlen(str), HAL_MAX_DELAY);
}

void Print_Status(void)
{
  char msg[100];
  snprintf(msg, sizeof(msg),
           "Count=%lu White=%u Last=%u\r\n",
           encoder_count,
           white_detected,
           last_white_state);
  UART2_SendString(msg);
}

/* USER CODE END 0 */

/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  HAL_Init();
  SystemClock_Config();
  MX_GPIO_Init();
  MX_USART2_UART_Init();

  /* USER CODE BEGIN 2 */
  last_white_state = TCRT5000_IsWhite();
  white_detected = last_white_state;

  HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, GPIO_PIN_RESET);

  UART2_SendString("\r\nTCRT5000 USART2 test started\r\n");
  UART2_SendString("PB0=input, PA5=LED, USART2=115200 over ST-LINK USB VCP\r\n");
  UART2_SendString("Move black and white under sensor\r\n\r\n");
  /* USER CODE END 2 */

  while (1)
  {
    uint32_t now = HAL_GetTick();

    /* Sample every 5 ms */
    if ((now - last_sample_time) >= 5U)
    {
      last_sample_time = now;

      white_detected = TCRT5000_IsWhite();

      /* Count only on transition into white */
      if ((white_detected == 1U) && (last_white_state == 0U))
      {
        encoder_count++;
        HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, GPIO_PIN_SET);
      }

      if (white_detected == 0U)
      {
        HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, GPIO_PIN_RESET);
      }

      last_white_state = white_detected;
    }

    /* Print every 200 ms */
    if ((now - last_print_time) >= 200U)
    {
      last_print_time = now;
      Print_Status();
    }
  }
}

