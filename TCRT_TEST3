/* Includes ------------------------------------------------------------------*/
#include "main.h"
#include <stdio.h>
#include <string.h>

/* Private variables ---------------------------------------------------------*/
ADC_HandleTypeDef hadc1;
UART_HandleTypeDef huart2;

/* USER CODE BEGIN PV */
volatile uint32_t sensor_adc = 0;
volatile uint32_t sensor_threshold = 2000;   // adjust after testing
volatile uint8_t sensor_digital = 0;         // 1 = white, 0 = black
volatile uint8_t last_sensor_digital = 0;
volatile uint32_t encoder_count = 0;
volatile uint32_t last_sample_time = 0;
volatile uint32_t last_print_time = 0;
/* USER CODE END PV */

/* Private function prototypes -----------------------------------------------*/
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_ADC1_Init(void);
static void MX_USART2_UART_Init(void);

/* USER CODE BEGIN PFP */
uint32_t TCRT_ReadADC(void);
uint8_t TCRT_ADC_To_Digital(uint32_t adc_value);
void UART2_SendString(const char *str);
void Print_Status(void);
/* USER CODE END PFP */

/* Private user code ---------------------------------------------------------*/
/* USER CODE BEGIN 0 */

uint32_t TCRT_ReadADC(void)
{
  HAL_ADC_Start(&hadc1);
  HAL_ADC_PollForConversion(&hadc1, HAL_MAX_DELAY);
  uint32_t value = HAL_ADC_GetValue(&hadc1);
  HAL_ADC_Stop(&hadc1);
  return value;
}

uint8_t TCRT_ADC_To_Digital(uint32_t adc_value)
{
  /* white = 1, black = 0
     If your sensor behaves backwards, change > to < */
  return (adc_value > sensor_threshold) ? 1U : 0U;
}

void UART2_SendString(const char *str)
{
  HAL_UART_Transmit(&huart2, (uint8_t *)str, strlen(str), HAL_MAX_DELAY);
}

void Print_Status(void)
{
  char msg[128];

  snprintf(msg, sizeof(msg),
           "ADC=%lu  DIG=%u  LAST=%u  COUNT=%lu  TH=%lu\r\n",
           sensor_adc,
           sensor_digital,
           last_sensor_digital,
           encoder_count,
           sensor_threshold);

  UART2_SendString(msg);
}

/* USER CODE END 0 */

/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  HAL_Init();
  SystemClock_Config();
  MX_GPIO_Init();
  MX_ADC1_Init();
  MX_USART2_UART_Init();

  /* USER CODE BEGIN 2 */
  HAL_Delay(100);

  HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_RESET);

  sensor_adc = TCRT_ReadADC();
  sensor_digital = TCRT_ADC_To_Digital(sensor_adc);
  last_sensor_digital = sensor_digital;

  UART2_SendString("\r\nTCRT ADC encoder monitor started\r\n");
  UART2_SendString("PA0 = ADC1_IN1, PA5 = LED, USART2 = 115200\r\n");
  UART2_SendString("Watch ADC, DIG, and COUNT in Tera Term\r\n\r\n");
  /* USER CODE END 2 */

  while (1)
  {
    uint32_t now = HAL_GetTick();

    /* sample every 2 ms */
    if ((now - last_sample_time) >= 2U)
    {
      last_sample_time = now;

      sensor_adc = TCRT_ReadADC();
      sensor_digital = TCRT_ADC_To_Digital(sensor_adc);

      /* count only on transition into white: 0 -> 1 */
      if ((sensor_digital == 1U) && (last_sensor_digital == 0U))
      {
        encoder_count++;
      }

      /* LED follows white detect */
      HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5,
                        sensor_digital ? GPIO_PIN_SET : GPIO_PIN_RESET);

      last_sensor_digital = sensor_digital;
    }

    /* print every 100 ms */
    if ((now - last_print_time) >= 100U)
    {
      last_print_time = now;
      Print_Status();
    }
  }
}

