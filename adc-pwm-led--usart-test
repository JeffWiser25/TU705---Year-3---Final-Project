/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  HAL_Init();
  SystemClock_Config();

  MX_GPIO_Init();
  MX_ADC2_Init();
  MX_TIM3_Init();
  MX_USART2_UART_Init();

  /* USER CODE BEGIN 2 */

  /* Calibrate ADC */
  if (HAL_ADCEx_Calibration_Start(&hadc2, ADC_SINGLE_ENDED) != HAL_OK)
  {
    Error_Handler();
  }

  /* Start PWM on TIM3 CH1 (PA6 assumed configured by CubeMX) */
  if (HAL_TIM_PWM_Start(&htim3, TIM_CHANNEL_1) != HAL_OK)
  {
    Error_Handler();
  }

  /* Start PWM at 0% duty */
  pwm_value = 0;
  __HAL_TIM_SET_COMPARE(&htim3, TIM_CHANNEL_1, pwm_value);

  snprintf(tx_buffer, sizeof(tx_buffer), "\r\nSystem Ready\r\n");
  HAL_UART_Transmit(&huart2, (uint8_t *)tx_buffer, strlen(tx_buffer), HAL_MAX_DELAY);

  snprintf(tx_buffer, sizeof(tx_buffer),
           "ADC: PA0 | PWM: TIM3_CH1 on PA6 | UART: USART2\r\n");
  HAL_UART_Transmit(&huart2, (uint8_t *)tx_buffer, strlen(tx_buffer), HAL_MAX_DELAY);

  snprintf(tx_buffer, sizeof(tx_buffer),
           "Type a message and press Enter.\r\n\r\n");
  HAL_UART_Transmit(&huart2, (uint8_t *)tx_buffer, strlen(tx_buffer), HAL_MAX_DELAY);

  last_uart_tick = HAL_GetTick();
  last_pwm_tick  = HAL_GetTick();

  /* USER CODE END 2 */

  while (1)
  {
    /* 1) Keep checking for UART input */
    Process_UART_Receive();

    /* 2) Update PWM sweep every 20 ms so LED visibly pulses */
    if ((HAL_GetTick() - last_pwm_tick) >= PWM_PERIOD_MS)
    {
      last_pwm_tick = HAL_GetTick();

      if (pwm_step > 0)
      {
        if ((pwm_value + (uint32_t)pwm_step) >= PWM_MAX)
        {
          pwm_value = PWM_MAX;
          pwm_step = -pwm_step;
        }
        else
        {
          pwm_value += (uint32_t)pwm_step;
        }
      }
      else
      {
        uint32_t step_mag = (uint32_t)(-pwm_step);

        if (pwm_value <= step_mag)
        {
          pwm_value = 0;
          pwm_step = -pwm_step;
        }
        else
        {
          pwm_value -= step_mag;
        }
      }

      __HAL_TIM_SET_COMPARE(&htim3, TIM_CHANNEL_1, pwm_value);
    }

    /* 3) Every 500 ms read ADC and send ADC/PWM values to Tera Term */
    if ((HAL_GetTick() - last_uart_tick) >= UART_PERIOD_MS)
    {
      last_uart_tick = HAL_GetTick();

      adc_raw = Read_ADC_Blocking();
      adc_mV = (adc_raw * ADC_REF_MV) / ADC_MAX_COUNTS;

      snprintf(tx_buffer, sizeof(tx_buffer),
               "ADC Raw: %lu | ADC mV: %lu | PWM: %lu\r\n",
               adc_raw, adc_mV, pwm_value);

      HAL_UART_Transmit(&huart2, (uint8_t *)tx_buffer, strlen(tx_buffer), HAL_MAX_DELAY);
    }
  }
}

