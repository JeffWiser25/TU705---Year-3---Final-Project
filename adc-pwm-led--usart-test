static uint32_t Read_ADC_Blocking(void)
{
  if (HAL_ADC_Start(&hadc2) != HAL_OK)
  {
    return 0;
  }

  if (HAL_ADC_PollForConversion(&hadc2, 10) != HAL_OK)
  {
    HAL_ADC_Stop(&hadc2);
    return 0;
  }

  uint32_t value = HAL_ADC_GetValue(&hadc2);

  HAL_ADC_Stop(&hadc2);

  return value;
}

static void Process_UART_Receive(void)
{
  /* Non-blocking receive: timeout = 0 */
  if (HAL_UART_Receive(&huart2, (uint8_t *)&rx_char, 1, 0) == HAL_OK)
  {
    /* Echo typed character back immediately if desired
       Uncomment next line if you want live character echo too */
    /* HAL_UART_Transmit(&huart2, (uint8_t *)&rx_char, 1, HAL_MAX_DELAY); */

    if ((rx_char == '\r') || (rx_char == '\n'))
    {
      if (rx_index > 0)
      {
        rx_buffer[rx_index] = '\0';

        snprintf(tx_buffer, sizeof(tx_buffer), "Received: %s\r\n", rx_buffer);
        HAL_UART_Transmit(&huart2, (uint8_t *)tx_buffer, strlen(tx_buffer), HAL_MAX_DELAY);

        rx_index = 0;
        memset(rx_buffer, 0, sizeof(rx_buffer));
      }
    }
    else
    {
      if (rx_index < (sizeof(rx_buffer) - 1))
      {
        rx_buffer[rx_index++] = (char)rx_char;
      }
      else
      {
        /* Buffer full: terminate and report */
        rx_buffer[sizeof(rx_buffer) - 1] = '\0';
        snprintf(tx_buffer, sizeof(tx_buffer), "Received: %s\r\n", rx_buffer);
        HAL_UART_Transmit(&huart2, (uint8_t *)tx_buffer, strlen(tx_buffer), HAL_MAX_DELAY);

        rx_index = 0;
        memset(rx_buffer, 0, sizeof(rx_buffer));
      }
    }
  }
}

