void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
  if (GPIO_Pin == TCRT_GPIO_PIN)
  {
    uint32_t now = HAL_GetTick();

    if ((now - last_rpm_pulse_tick) >= RPM_DEBOUNCE_MS)
    {
      rpm_pulse_count++;
      last_rpm_pulse_tick = now;
    }
  }
}

