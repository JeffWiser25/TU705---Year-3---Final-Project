/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  HAL_Init();
  SystemClock_Config();

  MX_GPIO_Init();
  MX_TIM3_Init();
  MX_USART2_UART_Init();

  if (HAL_TIM_PWM_Start(&htim3, TIM_CHANNEL_1) != HAL_OK)
  {
    Error_Handler();
  }

  __HAL_TIM_SET_COMPARE(&htim3, TIM_CHANNEL_1, 0);

  UART_Send("\r\nPI/PID Speed Control Ready\r\n");
  UART_Send("Feedback: TCRT5000 digital pulses on PA0/A0\r\n");
  UART_Send("PWM: TIM3 CH1 at 25 kHz\r\n");
  UART_Send("Type HELP for commands\r\n");

  last_control_tick = HAL_GetTick();
  last_status_tick = HAL_GetTick();
  last_rpm_tick = HAL_GetTick();

  while (1)
  {
    UART_ProcessRx();
    Update_Pulse_Count();
    Update_RPM();

    if ((HAL_GetTick() - last_control_tick) >= CONTROL_PERIOD_MS)
    {
      last_control_tick = HAL_GetTick();
      Control_Loop();
    }

    if ((HAL_GetTick() - last_status_tick) >= STATUS_PERIOD_MS)
    {
      last_status_tick = HAL_GetTick();
      Send_Status();
    }
  }
}

