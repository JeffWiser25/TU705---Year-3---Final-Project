static uint32_t ADC_ReadRaw(void)
{
  uint32_t value = 0U;

  if (HAL_ADC_Start(&hadc2) != HAL_OK)
  {
    return 0U;
  }

  if (HAL_ADC_PollForConversion(&hadc2, 10) == HAL_OK)
  {
    value = HAL_ADC_GetValue(&hadc2);
  }

  (void)HAL_ADC_Stop(&hadc2);
  return value;
}

static uint32_t ADC_ReadAverage(void)
{
  uint32_t sum = 0U;

  for (uint32_t i = 0; i < ADC_AVG_SAMPLES; i++)
  {
    sum += ADC_ReadRaw();
  }

  return (sum / ADC_AVG_SAMPLES);
}

static void UART_Send(const char *msg)
{
  HAL_UART_Transmit(&huart2, (uint8_t *)msg, (uint16_t)strlen(msg), HAL_MAX_DELAY);
}

static void Send_Status(void)
{
  int32_t kp_int = (int32_t)(Kp * 1000.0f);
  int32_t ki_int = (int32_t)(Ki * 1000.0f);
  int32_t kd_int = (int32_t)(Kd * 1000.0f);

  snprintf(tx_buffer, sizeof(tx_buffer),
           "DATA,%ld,%ld,%ld,%lu,%ld,%ld,%ld,%s,%u\r\n",
           (int32_t)setpoint,
           (int32_t)feedback,
           (int32_t)error,
           (unsigned long)pwm_value,
           (long)kp_int,
           (long)ki_int,
           (long)kd_int,
           (control_mode == CTRL_PI) ? "PI" : "PID",
           control_enabled);

  UART_Send(tx_buffer);
}

static void Process_Command(char *cmd)
{
  if (strncmp(cmd, "START", 5) == 0)
  {
    control_enabled = 1U;
    integral = 0.0f;
    prev_error = 0.0f;
    UART_Send("OK START\r\n");
  }
  else if (strncmp(cmd, "STOP", 4) == 0)
  {
    control_enabled = 0U;
    integral = 0.0f;
    prev_error = 0.0f;
    pwm_value = 0U;
    __HAL_TIM_SET_COMPARE(&htim3, TIM_CHANNEL_1, pwm_value);
    UART_Send("OK STOP\r\n");
  }
  else if (strncmp(cmd, "MODE PI", 7) == 0)
  {
    control_mode = CTRL_PI;
    UART_Send("OK MODE PI\r\n");
  }
  else if (strncmp(cmd, "MODE PID", 8) == 0)
  {
    control_mode = CTRL_PID;
    UART_Send("OK MODE PID\r\n");
  }
  else if (strncmp(cmd, "SP ", 3) == 0)
  {
    setpoint = (float)atof(&cmd[3]);

    if (setpoint < 0.0f) setpoint = 0.0f;
    if (setpoint > ADC_MAX_COUNTS) setpoint = ADC_MAX_COUNTS;

    integral = 0.0f;
    prev_error = 0.0f;

    UART_Send("OK SP\r\n");
  }
  else if (strncmp(cmd, "KP ", 3) == 0)
  {
    Kp = (float)atof(&cmd[3]);
    UART_Send("OK KP\r\n");
  }
  else if (strncmp(cmd, "KI ", 3) == 0)
  {
    Ki = (float)atof(&cmd[3]);
    UART_Send("OK KI\r\n");
  }
  else if (strncmp(cmd, "KD ", 3) == 0)
  {
    Kd = (float)atof(&cmd[3]);
    UART_Send("OK KD\r\n");
  }
  else if (strncmp(cmd, "STATUS", 6) == 0)
  {
    Send_Status();
  }
  else if (strncmp(cmd, "HELP", 4) == 0)
  {
    UART_Send("Commands:\r\n");
    UART_Send("START\r\nSTOP\r\nMODE PI\r\nMODE PID\r\n");
    UART_Send("SP <0-4095>\r\nKP <value>\r\nKI <value>\r\nKD <value>\r\n");
    UART_Send("STATUS\r\nHELP\r\n");
  }
  else
  {
    UART_Send("ERR UNKNOWN CMD\r\n");
  }
}

static void UART_ProcessRx(void)
{
  if (HAL_UART_Receive(&huart2, &rx_char, 1, 0) == HAL_OK)
  {
    if ((rx_char == '\r') || (rx_char == '\n'))
    {
      if (rx_index > 0U)
      {
        rx_buffer[rx_index] = '\0';
        Process_Command(rx_buffer);
        rx_index = 0U;
        memset(rx_buffer, 0, sizeof(rx_buffer));
      }
    }
    else
    {
      if (rx_index < (UART_RX_BUF_LEN - 1U))
      {
        rx_buffer[rx_index++] = (char)rx_char;
      }
    }
  }
}

static void Control_Loop(void)
{
  const float dt = (float)CONTROL_PERIOD_MS / 1000.0f;
  float new_integral;
  float u;

  adc_raw = ADC_ReadAverage();
  feedback = (float)adc_raw;
  error = setpoint - feedback;

  if (!control_enabled)
  {
    pwm_value = 0U;
    __HAL_TIM_SET_COMPARE(&htim3, TIM_CHANNEL_1, pwm_value);
    return;
  }

  derivative = (error - prev_error) / dt;

  new_integral = integral + (error * dt);

  if (new_integral > INTEGRAL_LIMIT) new_integral = INTEGRAL_LIMIT;
  if (new_integral < -INTEGRAL_LIMIT) new_integral = -INTEGRAL_LIMIT;

  u = (Kp * error) + (Ki * new_integral);

  if (control_mode == CTRL_PID)
  {
    u += (Kd * derivative);
  }

  if (u > PWM_MAX_COUNTS)
  {
    u = PWM_MAX_COUNTS;
  }
  else if (u < 0.0f)
  {
    u = 0.0f;
  }
  else
  {
    integral = new_integral;
  }

  control_output = u;
  pwm_value = (uint32_t)control_output;

  __HAL_TIM_SET_COMPARE(&htim3, TIM_CHANNEL_1, pwm_value);

  prev_error = error;
}

