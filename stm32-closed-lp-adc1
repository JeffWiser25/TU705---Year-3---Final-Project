/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  HAL_Init();
  SystemClock_Config();

  MX_GPIO_Init();
  MX_ADC2_Init();
  MX_TIM3_Init();
  MX_USART2_UART_Init();

  if (HAL_ADCEx_Calibration_Start(&hadc2, ADC_SINGLE_ENDED) != HAL_OK)
  {
    Error_Handler();
  }

  if (HAL_TIM_PWM_Start(&htim3, TIM_CHANNEL_1) != HAL_OK)
  {
    Error_Handler();
  }

  __HAL_TIM_SET_COMPARE(&htim3, TIM_CHANNEL_1, 0U);

  UART_Send("\r\nSimple ADC PI/PID Control Ready\r\n");
  UART_Send("PWM = TIM3 CH1 at 25 kHz\r\n");
  UART_Send("Feedback = ADC2 CH1\r\n");
  UART_Send("Type HELP for commands\r\n");

  last_control_tick = HAL_GetTick();
  last_status_tick = HAL_GetTick();

  BSP_LED_Init(LED_GREEN);
  BSP_PB_Init(BUTTON_USER, BUTTON_MODE_EXTI);

  while (1)
  {
    UART_ProcessRx();

    if ((HAL_GetTick() - last_control_tick) >= CONTROL_PERIOD_MS)
    {
      last_control_tick = HAL_GetTick();
      Control_Loop();
    }

    if ((HAL_GetTick() - last_status_tick) >= STATUS_PERIOD_MS)
    {
      last_status_tick = HAL_GetTick();
      Send_Status();
    }
  }
}

