/* USER CODE BEGIN 0 */

uint8_t TCRT5000_IsWhite(void)
{
  /* If it counts black instead of white, change RESET to SET */
  return (HAL_GPIO_ReadPin(TCRT_GPIO_Port, TCRT_Pin) == GPIO_PIN_RESET) ? 1U : 0U;
}

void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
  if (GPIO_Pin == TCRT_Pin)
  {
    uint8_t current_white = TCRT5000_IsWhite();
    uint32_t now = HAL_GetTick();

    /* Count only on a 0 -> 1 transition, with 20 ms debounce */
    if ((current_white == 1U) &&
        (last_white_state == 0U) &&
        ((now - last_count_time) > 20U))
    {
      encoder_count = encoder_count + 1U;
      last_count_time = now;

      HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, GPIO_PIN_SET);
      led_off_time = now + 1000U;
    }

    white_detected = current_white;
    last_white_state = current_white;
  }
}

/* USER CODE END 0 */

/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  HAL_Init();
  SystemClock_Config();
  MX_GPIO_Init();

  /* USER CODE BEGIN 2 */
  last_white_state = TCRT5000_IsWhite();
  white_detected = last_white_state;
  HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, GPIO_PIN_RESET);
  led_off_time = 0U;
  last_count_time = 0U;
  /* USER CODE END 2 */

  while (1)
  {
    if ((led_off_time != 0U) && ((int32_t)(HAL_GetTick() - led_off_time) >= 0))
    {
      HAL_GPIO_WritePin(LED_GPIO_Port, LED_Pin, GPIO_PIN_RESET);
      led_off_time = 0U;
    }

    if (encoder_count > 0U)
    {
      __NOP();
    }
  }
}

