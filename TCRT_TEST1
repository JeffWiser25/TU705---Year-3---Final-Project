#define LED_GPIO_Port    GPIOA
#define LED_Pin          GPIO_PIN_5
/* USER CODE END PD */

/* Private variables ---------------------------------------------------------*/
/* USER CODE BEGIN PV */
volatile uint32_t encoder_count = 0;
volatile uint8_t white_detected = 0;
volatile uint8_t last_white_state = 0;
volatile uint32_t led_off_time = 0;
volatile uint32_t last_count_time = 0;
/* USER CODE END PV */

/* Private function prototypes -----------------------------------------------*/
void SystemClock_Config(void);
static void MX_GPIO_Init(void);

/* USER CODE BEGIN PFP */
uint8_t TCRT5000_IsWhite(void);
/* USER CODE END PFP */

